{
  "name": "pco-service-dashboard",
  "version": "1.0.0",
  "description": "Planning Center Services display dashboard for meeting room TV",
  "author": "Wesley",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "desktop": "electron .",
    "dist": "electron-builder --win --mac"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.wesleypco.dashboard",
    "productName": "PCO Service Dashboard",
    "asar": true,
    "files": [
      "app-server.js",
      "electron-main.js",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  }
}
